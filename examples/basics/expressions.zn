void main(){
    int a = 10
    int b = 3

    int sum = a + b
    int diff = a - b
    int prod = a * b
    int quot = a / b
    int rem = a % b

    println(sum)
    println(diff)
    println(prod)
    println(quot)
    println(rem)

    int grouped = (10 + 5) * 2
    println(grouped)

    a = a + 1
    println(a)
}
